# Database Connections
# Copy this file to .env and fill in your actual credentials

# Seagate DB (sghu-db02)
DB_SEAGATE_HOST=sghu-db02.th.belton.corp
DB_SEAGATE_USER=appsupport8
DB_SEAGATE_PASSWORD=your_password_here
DB_SEAGATE_DATABASE=seagate

# ACA DB (same host)
DB_ACA_HOST=sghu-db02.th.belton.corp
DB_ACA_USER=appsupport8
DB_ACA_PASSWORD=your_password_here
DB_ACA_DATABASE=ACA

# Bitintra DB
DB_BITINTRA_HOST=bitintra-db02.th.belton.corp
DB_BITINTRA_USER=intranet4
DB_BITINTRA_PASSWORD=your_password_here

# WMS & BIT DBs
DB_WMS_HOST=bitintra-db02.th.belton.corp
DB_WMS_USER=adminapp
DB_WMS_PASSWORD=your_password_here
DB_WMS_DATABASE=WMS

# SeagateDev (metadata tables)
DB_SEAGATEDEV_HOST=devth-db2.th.belton.corp
DB_SEAGATEDEV_USER=adminapp
DB_SEAGATEDEV_PASSWORD=your_password_here
DB_SEAGATEDEV_DATABASE=seagate

# Port
DB_PORT=3306

# HTTPS/TLS (optional)
ENABLE_TLS=false
SSL_CERT_PATH=/etc/httpd/conf/ssl.crt/beltontechnology_com.crt
SSL_KEY_PATH=/etc/httpd/conf/ssl.crt/beltontechnology_com.key
SSL_CA_PATH=/etc/httpd/conf/ssl.crt/beltontechnology_com.ca-bundle
